# Weight Watchers credentials — use email+password for unattended runs
WW_EMAIL=you@example.com
WW_PASSWORD=yourpassword

# Or use a JWT instead (expires ~2 hours after browser login — not practical for scheduled runs)
# WW_JWT=eyJ0eX...

# Google Sheets
GOOGLE_SHEET_ID=your_google_sheet_id_here
# Path to service account key file (default: service-account-key.json in project root)
# GOOGLE_SERVICE_ACCOUNT_KEY=service-account-key.json

# WW website TLD (default: com — change to co.uk etc. if needed)
# WW_TLD=com
